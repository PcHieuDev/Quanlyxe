{
  "manifest_version": 3,
  "name": "VNPOST & Quanlyxe Unified Tools",
  "version": "1.3.0",
  "description": "Bộ công cụ tiện ích tổng hợp cho báo cáo VNPOST và đồng bộ dữ liệu Quanlyxe",
  "icons": {
    "128": "icons/logo_menu.png"
  },
  "action": {
    "default_title": "Bộ công cụ VNPOST & Quanlyxe",
    "default_icon": {
      "128": "icons/logo_menu.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://dkcl.vnpost.vn/*", 
    "https://api.jsonbin.io/*",
    "http://10.42.40.20:8388/*",
    "https://script.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://dkcl.vnpost.vn/*"],
      "js": ["content-sidebar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://report.vnpost.vn/*"],
      "css": ["vnpost_styles.css"],
      "js": ["vnpost_content.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://quanlyxe.vn/*", "*://www.quanlyxe.vn/*"],
      "css": ["quanlyxe_styles.css"],
      "js": ["quanlyxe_content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.css", "popup.js", "icons/logo_menu.png"],
      "matches": ["https://dkcl.vnpost.vn/*"]
    }
  ]
}
